---
import { Button } from "@/components/ui/button"
import { ThemeToggle } from "@/components/react/ThemeToggle"
import { SocialLinks } from "@/components/react/SocialLinks"
---

<header
  class="fixed inset-x-0 top-0 z-40 transition-all"
  data-nav
>
  <div class="mx-auto mt-4 max-w-6xl px-4">
    <div
      class="flex items-center justify-between gap-4 rounded-2xl border border-transparent bg-background/0 px-5 py-3 backdrop-blur-0 transition-all"
      data-nav-inner
    >
      <a href="/" class="flex items-center gap-2 text-base font-semibold tracking-tight">
        <span class="relative flex size-7 items-center justify-center rounded-lg bg-gradient-to-br from-primary to-amber-400 text-primary-foreground shadow-sm">
          <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/>
            <line x1="6" x2="18" y1="17" y2="17"/>
          </svg>
        </span>
        Maitre
      </a>
      <nav class="hidden items-center gap-1 md:flex">
        <a href="#beneficios" class="rounded-md px-3 py-1.5 text-sm text-muted-foreground transition hover:text-foreground">Beneficios</a>
        <a href="#roles" class="rounded-md px-3 py-1.5 text-sm text-muted-foreground transition hover:text-foreground">Por rol</a>
        <a href="#precios" class="rounded-md px-3 py-1.5 text-sm text-muted-foreground transition hover:text-foreground">Precios</a>
        <a href="#faq" class="rounded-md px-3 py-1.5 text-sm text-muted-foreground transition hover:text-foreground">FAQ</a>
      </nav>
      <div class="flex items-center gap-2">
        <div class="hidden sm:flex">
          <SocialLinks client:idle compact />
        </div>
        <ThemeToggle client:idle />
        <Button size="sm">Demo</Button>
      </div>
    </div>
  </div>
</header>

<script>
  const inner = document.querySelector('[data-nav-inner]') as HTMLElement | null
  function onScroll() {
    if (!inner) return
    if (window.scrollY > 12) {
      inner.classList.add('!border-border', '!bg-background/70', '!backdrop-blur-xl', 'shadow-sm')
    } else {
      inner.classList.remove('!border-border', '!bg-background/70', '!backdrop-blur-xl', 'shadow-sm')
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true })
  onScroll()
</script>
