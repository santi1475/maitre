---
import "@/styles/globals.css"
import ThemeScript from "@/components/ThemeScript.astro"

interface Props {
  title?: string
  description?: string
}

const {
  title = "Maitre · Sistema de gestión para restaurantes",
  description = "Pedidos, mesas, cocina y cierres en tiempo real. Auditoría exhaustiva, idempotencia end-to-end y operación multi-sucursal.",
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ThemeScript />
  </head>
  <body class="bg-cream dark:bg-[#111009] text-ink dark:text-[#e8e4dc] font-sans antialiased">
    <slot />
  </body>
</html>
