---
import Layout from "../layouts/Layout.astro"
import {
  Navbar,
  Hero,
  Mockups,
  Flujo,
  Roles,
  Testimonios,
  Precios,
  CTAFinal,
  Footer,
} from "../components/landing"
---

<Layout title="Maitre - Gestión Inteligente para Restaurantes">
  <Navbar client:load />
  <main class="overflow-x-hidden">
    <Hero client:load />
    <Mockups client:visible />
    <Flujo client:visible />
    <Roles client:visible />
    <Testimonios client:visible />
    <Precios client:visible />
    <CTAFinal client:visible />
  </main>
  <Footer />
</Layout>
